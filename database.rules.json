      ".read": true,
      ".indexOn": ["trophies", "nicknameNormalized"],
      "$profileId": {
        ".write": true
      }
    },
    "nicknames": {
      ".read": true,
      "$nickname": {
        ".write": true
      }
    },
    "publicIds": {
      ".read": true,
      "$publicId": {
        ".write": true
      }
    },
    "accounts": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "saveBlobs": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "friendLinks": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "friendInvites": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "friendInviteSent": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "partyInvites": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "partyInviteSent": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "partyMemberships": {
      ".read": true,
      "$profileId": {
        ".write": true
      }
    },
    "parties": {
      ".read": true,
      "$partyId": {
        ".write": true
      }
    }
  }
